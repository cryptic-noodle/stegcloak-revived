{
  "name": "stegcloak-revived",
  "type": "module",
  "workspaces": [
    "packages/core",
    "webapp"
  ],
  "keywords": [
    "cryptography",
    "steganography",
    "unicode",
    "compression",
    "steganography-algorithms"
  ],
  "version": "2.0.0",
  "main": "stegcloak.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build:core": "npm run build --prefix packages/core",
    "build:webapp": "npm run build --prefix webapp",
    "build": "npm run build:core && npm run build:webapp",
    "verify": "node verify-v2.js",
    "test": "node verify-v2.js"
  },
  "license": "MIT",
  "bin": {
    "stegcloak": "./cli.js"
  },
  "homepage": "https://github.com/cryptic-noodle/stegcloak-revived#readme",
  "description": "StegCloak Revived — hide encrypted secrets inside plain text using invisible Unicode characters. A modernized fork of the original StegCloak with Argon2id/XChaCha20-Poly1305 encryption and zstd compression.",
  "repository": {
    "type": "git",
    "url": "https://github.com/cryptic-noodle/stegcloak-revived"
  },
  "dependencies": {
    "@stegcloak/core": "*",
    "chalk": "^5.4.1",
    "clipboardy": "^4.0.0",
    "commander": "^13.1.0",
    "inquirer": "^12.6.3",
    "jsonfile": "^6.1.0",
    "libsodium-wrappers-sumo": "^0.8.4",
    "ora": "^8.2.0",
    "zstd-codec": "^0.1.5"
  }
}
